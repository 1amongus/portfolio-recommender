{
  "name": "portfolio-recommender",
  "version": "1.0.0",
  "description": "Yield-targeted portfolio optimization with Beta minimization. Electron desktop app.",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:vite": "vite build",
